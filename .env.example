PROJECT_NAME=ML Research Accelerator
VERSION=1.0.0
DEBUG=False

# HTTP API aggregation_service (uvicorn)
API_HOST=0.0.0.0
# Порт FastAPI
API_PORT=8002

POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ml_platform

# Пул async SQLAlchemy (размер и «запас» соединений сверх пула)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Брокер и backend 
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Жёсткий лимит времени задачи, сек
CELERY_TASK_TIME_LIMIT=86400
# Мягкий лимит, сек
CELERY_TASK_SOFT_TIME_LIMIT=84600
# Число процессов воркера prefork (=2: Kaggle и UCI не блокируют друг друга в одной очереди)
CELERY_WORKER_CONCURRENCY=2
# Очередь для задач EDA; воркер агрегации слушает только celery
CELERY_EDA_QUEUE=eda

# Задержка перед постановкой стартовых Celery-задач после поднятия API, минуты
AGGREGATION_STARTUP_DELAY_MINUTES=1
# Интервал периодической задачи Beat для Kaggle, дни
KAGGLE_UPDATE_INTERVAL_DAYS=1ч
# Интервал периодической задачи Beat для UCI, дни
UCI_UPDATE_INTERVAL_DAYS=7

# Первичная агрегация: страница каталога Kaggle, порции обработки
AGGREGATION_BATCH_SIZE=100
# Проверка обновлений: сколько активных строк datasets за один запрос из БД
UPDATE_BATCH_SIZE=10
# Максимальный размер одного файла датасета при валидации/обновлении, КБ (0 байт — всегда отклоняется)
MAX_FILE_SIZE_KB=102400

# Максимальное время одного HTTP-запроса (таймаут)
HTTP_CLIENT_TIMEOUT_SECONDS=120
# Максимальное количество попыток выполнить запрос при ошибке
HTTP_CLIENT_MAX_RETRIES=3
# Задержка между попытками выполнить запрос при ошибке
HTTP_CLIENT_RETRY_DELAY_SECONDS=1.0
# Пауза между запросами UCI/HTML (общий BaseClient)
HTTP_CLIENT_RATE_LIMIT_DELAY_SECONDS=0.5
# Пауза между запросами Kaggle (каталог и 429)
KAGGLE_HTTP_RATE_LIMIT_DELAY_SECONDS=1.0
# Лимит повторов для 429 при обходе каталога Kaggle
KAGGLE_LIST_429_MAX_RETRIES=5
# Лимит повторов для 429 для остальных вызовов Kaggle API
KAGGLE_CALL_429_MAX_RETRIES=5

# UCI
# true - в каталог только датасеты с filter=python (как ucimlrepo). false - весь API-список
UCI_CATALOG_FILTER_PYTHON=true
# true - не пропускать полную сверку UCI только из-за совпадения даты обновления датасета
UCI_SKIP_DATE_OPTIMIZATION=false
# true - при update пересчитывать хеш data-файлов даже если размер не изменился
UCI_FORCE_HASH_RECALC_ON_SAME_SIZE=true

# Kaggle
# true - не пропускать полную сверку Kaggle только из-за совпадения даты обновления датасета
KAGGLE_SKIP_DATE_OPTIMIZATION=false
# true - при update пересчитывать хеш data-файлов даже если размер не изменился
KAGGLE_FORCE_HASH_RECALC_ON_SAME_SIZE=true

# Kaggle API токен
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-api-key

# JWT
SECRET_KEY=your-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:3000,http://localhost:5173

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s