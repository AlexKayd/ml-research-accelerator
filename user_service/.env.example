PROJECT_NAME=ML Research User Service
VERSION=1.0.0
DEBUG=False

API_PORT=8001

# JWT secret
SECRET_KEY=your-secret-key
# JWT алгоритм
ALGORITHM=HS256
# Время жизни access token (минуты)
ACCESS_TOKEN_EXPIRE_MINUTES=30
# Время жизни refresh token (дни)
REFRESH_TOKEN_EXPIRE_DAYS=7

# Общий секрет с eda_service, должен совпадать с eda_service
EDA_SERVICE_INTERNAL_TOKEN=your_secret_token

# Разрешенные CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Уровень логирования
LOG_LEVEL=INFO
# Формат логов
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s