PROJECT_NAME=ML Research Aggregation Service
VERSION=1.0.0
DEBUG=False

API_PORT=8002

# URL брокера Celery
CELERY_BROKER_URL=redis://redis:6379/1
# URL backend Celery
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Жесткий таймлимит Celery-задач (секунды)
CELERY_TASK_TIME_LIMIT=86400
# Мягкий таймлимит Celery-задач (секунды)
CELERY_TASK_SOFT_TIME_LIMIT=84600
# Параллельность Celery воркера aggregation_service
CELERY_WORKER_CONCURRENCY=2
# Очередь, в которую отправляются события для EDA
CELERY_EDA_QUEUE=eda

# Задержка перед стартовыми задачами после запуска API (минуты)
AGGREGATION_STARTUP_DELAY_MINUTES=1
# Период update Kaggle (дни)
KAGGLE_UPDATE_INTERVAL_DAYS=1
# Период update UCI (дни)
UCI_UPDATE_INTERVAL_DAYS=7

# Размер батча первичной агрегации
AGGREGATION_BATCH_SIZE=100
# Размер батча update активных датасетов
UPDATE_BATCH_SIZE=10

# Максимальный размер одного файла (КБ)
MAX_FILE_SIZE_KB=102400

# Таймаут HTTP-запроса к источникам (сек)
HTTP_CLIENT_TIMEOUT_SECONDS=120
# Количество HTTP-повторов при ошибке
HTTP_CLIENT_MAX_RETRIES=3
# Задержка между HTTP-повторами (сек)
HTTP_CLIENT_RETRY_DELAY_SECONDS=1.0
# Базовая пауза между HTTP-запросами (сек)
HTTP_CLIENT_RATE_LIMIT_DELAY_SECONDS=0.5

# Ограничивать UCI-каталог только filter=python
UCI_CATALOG_FILTER_PYTHON=true
# Отключить skip-оптимизацию update по дате для UCI
UCI_SKIP_DATE_OPTIMIZATION=false
# Всегда пересчитывать хеш data-файлов при update UCI, даже если размер не изменился
UCI_FORCE_HASH_RECALC_ON_SAME_SIZE=true

# Пауза для Kaggle HTTP-запросов (сек)
KAGGLE_HTTP_RATE_LIMIT_DELAY_SECONDS=1.0
# Повторы при 429 для Kaggle dataset_list
KAGGLE_LIST_429_MAX_RETRIES=5
# Повторы при 429 для остальных вызовов Kaggle API
KAGGLE_CALL_429_MAX_RETRIES=5

# Отключить skip-оптимизацию update по дате для Kaggle
KAGGLE_SKIP_DATE_OPTIMIZATION=false
# Всегда пересчитывать хеш data-файлов при update Kaggle, даже если размер не изменился
KAGGLE_FORCE_HASH_RECALC_ON_SAME_SIZE=true
# Логин Kaggle API
KAGGLE_USERNAME=your-kaggle-username
# API-ключ Kaggle
KAGGLE_KEY=your-kaggle-api-key

# Разрешенные CORS origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Уровень логирования
LOG_LEVEL=INFO
# Формат логов
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s