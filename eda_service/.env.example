PROJECT_NAME=ML Research Accelerator EDA Service
VERSION=1.0.0
DEBUG=False

API_PORT=8003

# Redis URL для health-check, rate limit и тд
REDIS_URL=redis://redis:6379/1
# URL брокера Celery
CELERY_BROKER_URL=redis://redis:6379/1
# URL backend Celery
CELERY_RESULT_BACKEND=redis://redis:6379/1
# Жесткий таймлимит Celery-задач (сек)
CELERY_TASK_TIME_LIMIT=86400
# Мягкий таймлимит Celery-задач (сек)
CELERY_TASK_SOFT_TIME_LIMIT=84600
# Очередь событий от aggregation_service
CELERY_EDA_QUEUE=eda
# Очередь генерации отчетов
CELERY_GEN_QUEUE=eda_gen
# Очередь ожидалок
CELERY_WAITER_QUEUE=eda_waiter
# Привязка отчёта к пользователю в user_service
CELERY_NOTIFY_QUEUE=eda_notify

# Ворер, слушает простые задачи
CELERY_WORKER_CONCURRENCY=3
# Ворер, слушает тяжелые задачи (генерация отчетов)
CELERY_GEN_WORKER_CONCURRENCY=2

# Через сколько часов completed отчет считать потенциально устаревшим
REPORT_STALE_AFTER_HOURS=24
# Через сколько минут processing считать зависшим
REPORT_STUCK_AFTER_MINUTES=30
# Интервал Celery Beat для поиска зависших отчётов (мин)
STUCK_REPORTS_BEAT_INTERVAL_MINUTES=5
# Интервал пуллинга у задачи-ожидалки (сек)
WAITER_POLL_INTERVAL_SECONDS=5
# Максимальное время ожидания ожидалкой (мин)
WAITER_MAX_WAIT_MINUTES=120
# Лимит запросов генерации на пользователя в минуту
GENERATE_RATE_LIMIT_PER_MINUTE=10
# TTL Redis ключа подписчиков на отчёт
REPORT_SUBSCRIBERS_REDIS_TTL_SECONDS=604800
# Минимальный интервал между постановками notify для одной пары user/report (анти спам)
REPORT_ATTACH_ENQUEUE_COOLDOWN_SECONDS=3600

# тот же SECRET_KEY и ALGORITHM что в user_service
SECRET_KEY=your_secret_token
ALGORITHM=HS256

MINIO_ENDPOINT=minio:9000
# Публичный ключ доступа к MinIO
MINIO_ACCESS_KEY=minioadmin
# Секретный ключ доступа к MinIO
MINIO_SECRET_KEY=minioadmin
# Использовать HTTPS для MinIO
MINIO_SECURE=false
# Bucket для HTML-отчетов
MINIO_REPORTS_BUCKET=eda-reports
# Авто-создавать bucket, если его нет
MINIO_AUTO_CREATE_BUCKET=true
# Публичная база URL для report_ur
MINIO_PUBLIC_BASE_URL=http://localhost:9000
# Анонимное чтение объектов в бакете отчётов, чтобы report_url открывался в браузере
MINIO_REPORTS_BUCKET_ANONYMOUS_READ=true

# URL user_service для привязки user_id и report_id
USER_SERVICE_URL=http://user_service:8001
# Таймаут HTTP к user_service (сек)
USER_SERVICE_HTTP_TIMEOUT_SECONDS=60
# Таймаут HTTP клиента (сек)
HTTP_CLIENT_TIMEOUT_SECONDS=120
# Celery-задача notify макс число повторов при недоступности user_service
USER_SERVICE_NOTIFY_MAX_RETRIES=30
# Celery notify базовая задержка экспоненциальная (сек)
USER_SERVICE_NOTIFY_RETRY_BASE_DELAY_SECONDS=2.0
# Celery notify потолок задержки между повторами (сек)
USER_SERVICE_NOTIFY_RETRY_MAX_DELAY_SECONDS=300.0

# Общий секрет с user_service должен совпадать с user_service
EDA_SERVICE_INTERNAL_TOKEN=your_secret_token

# Разрешенные CORS origins
CORS_ORIGINS=http://localhost:5173

# Уровень логирования
LOG_LEVEL=INFO
# Формат логов
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s